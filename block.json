{
    "$schema": "https://wp.org",
    "apiVersion": 3,
    "name": "fambach/related-posts",
    "title": "Related Posts",
    "category": "widgets",
    "icon": "list-view",
    "description": "Zeigt verwandte Beiträge basierend auf Kategorien an.",
    "attributes": {
        "beitraege_aktivieren": {
            "type": "boolean",
            "default": true
        },
        "ueberschrift_text": {
            "type": "string",
            "default": "Verwandte Beiträge"
        },
        "ueberschrift_typ": {
            "type": "string",
            "default": "h2"
        },
        "anzahl_beitraege": {
            "type": "integer",
            "default": 5
        },
        "kategorie_modus": {
            "type": "string",
            "default": "automatisch"
        },
        "eigene_kategorien_ids": {
            "type": "array",
            "default": []
        },
        "debug_modus": {
            "type": "boolean",
            "default": false
        }
    },
    "supports": {
        "align": true
    }
}
